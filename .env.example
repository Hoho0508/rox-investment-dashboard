# 複製成 .env 後再填入；此檔只能保留假值或空值，不可提交真實密鑰。
# PostgreSQL 是報告、日誌、自選股與登入狀態所需的持久層。
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# 本機未設定任何行情 Key 時使用 mock，所有畫面仍可離線開發與測試。
DATA_MODE="mock"

# 下列安全值請在自己的 .env 產生，不可沿用範例文字。
CRON_SECRET="replace-with-a-long-random-secret"
APP_ACCESS_PASSWORD="replace-with-a-strong-private-password"
SESSION_SECRET="replace-with-an-independent-32-character-random-secret"
REPORT_TIME_ZONE="Asia/Taipei"
REPORT_MAX_RETRIES="2"

# 選用 Live Provider；留空時 DATA_MODE=mock 仍可完整執行介面。
FINMIND_API_TOKEN=""
FUGLE_MARKETDATA_API_KEY=""
# LIVE_MARKET_API_KEY=""
# LIVE_NEWS_API_KEY=""
